# 피부텐텐 Supabase 환경변수
# 1) https://supabase.com 접속 → New Project → 'pibutenten' (region: Northeast Asia (Seoul))
# 2) Project Settings → API 에서 아래 값 복사
# 3) 본 파일을 .env.local 로 복사 후 값 채우기 (커밋 금지)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 서버 전용 (절대 클라이언트 노출 금지). 관리 작업·Service Role 사용 시.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 사이트 URL — 자체 도메인 이전 시 변경 (sitemap.xml/robots.txt/JSON-LD/canonical 모두 자동 반영)
# 미설정 시 https://pibutenten-webapp.vercel.app 사용
# NEXT_PUBLIC_SITE_URL=https://pibutenten.com

# ─────────────────────────────────────────────────────────────
# 네이버 간편 로그인 (Supabase 미지원 → 자체 OAuth 흐름)
# 1) https://developers.naver.com/apps/ → Application 등록
#    - 사용 API: 네이버 로그인
#    - 환경: PC웹, Mobile웹
#    - 서비스 URL: https://pibutenten-webapp.vercel.app
#    - Callback URL: https://pibutenten-webapp.vercel.app/api/auth/naver/callback
#    - 제공 정보 동의: 이메일(필수) + 이름·프로필사진(선택)
# 2) 발급받은 Client ID/Secret 아래에 입력
# 3) 둘 다 비어 있으면 네이버 버튼 클릭 시 로그인 안내 메시지 표시
# ─────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ANTHROPIC (글 초안 생성용)
ANTHROPIC_API_KEY=
