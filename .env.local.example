# 피부텐텐 Supabase 환경변수
# 1) https://supabase.com 접속 → New Project → 'pibutenten' (region: Northeast Asia (Seoul))
# 2) Project Settings → API 에서 아래 값 복사
# 3) 본 파일을 .env.local 로 복사 후 값 채우기 (커밋 금지)

# Production 은 Supabase Custom Domain 사용: https://auth.pibutenten.kr (ADR 0018)
# 로컬·신규 셋업은 아래 프로젝트 ref 직결 주소 그대로.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 서버 전용 (절대 클라이언트 노출 금지). 관리 작업·Service Role 사용 시.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Supabase Management API (마이그레이션 production 적용용 — CLAUDE.md §8)
# https://supabase.com/dashboard/account/tokens 에서 발급
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ─────────────────────────────────────────────────────────────
# CSRF Origin allowlist (middleware.ts) — ADR 0012 정합
# 콤마 구분. 빈 값이면 production 도메인 (pibutenten.kr / www + 레거시 pbtt.kr) 만 허용.
# dev 환경에서 본인 LAN IP 로 접근 시 여기에 추가:
#   CSRF_ALLOWED_ORIGINS=http://192.168.0.20:3000,http://localhost:3000
# preview 환경: pibutenten-webapp-*.vercel.app 패턴은 코드에서 자동 허용
# ─────────────────────────────────────────────────────────────
CSRF_ALLOWED_ORIGINS=

# 사이트 URL — 자체 도메인 (sitemap.xml/robots.txt/JSON-LD/canonical + CSRF Origin 매칭 자동 반영)
# 참조: src/lib/site.ts, src/middleware.ts, src/app/api/admin/youtube-oauth/*
# Production: https://pibutenten.kr (Vercel env에 설정됨)
# Preview/Local: 미설정(빈 값) 시 https://pibutenten-webapp.vercel.app fallback
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────
# 네이버 간편 로그인 (Supabase 미지원 → 자체 OAuth 흐름)
# 1) https://developers.naver.com/apps/ → Application 등록
#    - 사용 API: 네이버 로그인
#    - 환경: PC웹, Mobile웹
#    - 서비스 URL: https://pibutenten.kr
#    - Callback URL: https://pibutenten.kr/api/auth/naver/callback
#    - 제공 정보 동의: 이메일(필수) + 이름·프로필사진(선택)
# 2) 발급받은 Client ID/Secret 아래에 입력
# 3) 둘 다 비어 있으면 네이버 버튼 클릭 시 로그인 안내 메시지 표시
# ─────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ANTHROPIC (글 초안 생성용)
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# YouTube 자막·메타 (admin 글 초안 파이프라인)
#   OAuth 3종: 피부텐텐 본인 채널 영상 자막 다운로드 최우선 경로.
#     - Google Cloud Console → OAuth 클라이언트 (YouTube Data API v3)
#     - REFRESH_TOKEN 은 DB(youtube_oauth_tokens) 우선, env 는 dev 초기 세팅용 fallback
#     - 참조: src/lib/ai/youtube-oauth.ts, src/app/api/admin/youtube-oauth/*
#   YOUTUBE_API_KEY: Data API v3 키 — 링크 미리보기 영상 메타 조회.
#     - 참조: src/app/api/preview-link/route.ts (미설정 시 oEmbed 등 fallback)
# ─────────────────────────────────────────────────────────────
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_API_KEY=

# ─────────────────────────────────────────────────────────────
# PubMed E-utilities (NCBI) — 시술 근거 문헌 검색 (admin 초안 도구)
#   미설정도 동작(공용 rate limit). 키 설정 시 요청 한도 상향.
#   발급: https://www.ncbi.nlm.nih.gov/account/settings/ → API Key
#   참조: src/lib/ai/pubmed.ts
# ─────────────────────────────────────────────────────────────
NCBI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Python 자막 fetch (youtube-transcript-api) — 외부 채널 영상 fallback
#   - PYTHON_BIN: 로컬 python 실행 파일 경로 (Windows 는 Microsoft Store stub 회피 위해
#     PYTHON_BIN=C:/path/to/python.exe 권장. 미설정 시 OS별 기본 후보 탐색)
#   - PYTHON_TRANSCRIPT_DISABLED=1 이면 이 통로 전체 비활성
#   - PYTHON_TRANSCRIPT_SECRET: Vercel /api/transcript 호출 인증 헤더(X-Transcript-Secret)
#   참조: src/lib/ai/python-transcript.ts, scripts/fetch_transcript.py
# ─────────────────────────────────────────────────────────────
PYTHON_BIN=
PYTHON_TRANSCRIPT_DISABLED=
PYTHON_TRANSCRIPT_SECRET=

# ─────────────────────────────────────────────────────────────
# PWA Push Notification — Web Push API (VAPID)
# - 키 생성: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# - 한 번 생성 후 변경 금지 (기존 구독자 전부 무효화됨)
# - VAPID_SUBJECT: mailto: 또는 https:// 형식. web-push 표준.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:pibutenten@gmail.com
# Supabase Database Webhook 인증용 비밀키 (notifications INSERT 시 호출됨)
# Dashboard → Database → Webhooks 등록 시 헤더 x-pibutenten-push-secret = $PUSH_WEBHOOK_SECRET
PUSH_WEBHOOK_SECRET=
# 네이티브 앱(iOS/Android) FCM 푸시 발송용 Firebase 서비스계정 키 (JSON 전문 한 줄).
# - Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성으로 발급.
# - 미설정 시 네이티브 푸시만 비활성(웹 푸시는 정상). 운영은 Vercel 환경변수로 관리.
# - 예: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...",...}'
FIREBASE_SERVICE_ACCOUNT=

# ─────────────────────────────────────────────────────────────
# 사이트 공개 스위치 — fail-safe HOLD 패턴 (robots.ts + sitemap.ts)
#   정확히 "true" 일 때만 검색엔진 색인 허용. 그 외 (미설정/오타/빈값) 모두 전체 차단.
#   Production 만 "true" 권장. Preview/Development 는 그대로 차단 유지.
# ─────────────────────────────────────────────────────────────
SITE_PUBLIC=

# ─────────────────────────────────────────────────────────────
# 검색엔진 사이트 인증 토큰 (HTML 메타태그 방식)
#   비어 있으면 해당 메타태그 자체가 렌더되지 않음 (빈 메타 차단).
#   - Google Search Console: https://search.google.com/search-console (URL 접두어 속성)
#   - 네이버 서치어드바이저: https://searchadvisor.naver.com
#   - Bing Webmaster Tools: https://www.bing.com/webmasters
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────
# Analytics 스택 (Vercel Analytics + Speed Insights 는 ID 발급 불필요 — 패키지 자동 동작)
#   값이 비어 있으면 해당 스크립트 자체가 로드되지 않음 (fail-safe).
#   - GA4: https://analytics.google.com → 속성 → 데이터 스트림 → 측정 ID
#   - 네이버 Analytics: https://analytics.naver.com → 사이트 추가 → 발급코드
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_NAVER_ANALYTICS_ID=

# ─────────────────────────────────────────────────────────────
# IndexNow (Bing/Yandex/Seznam/Yep 일괄 색인 통보)
#   - INDEXNOW_KEY: 32자 이상 hex/UUID. public/{key}.txt 와 동일 값 호스팅 필수 (소유권 증명).
#   - 매일 KST 04:00 (vercel.json crons) /api/cron/indexnow 자동 호출.
# ─────────────────────────────────────────────────────────────
INDEXNOW_KEY=
# Vercel Cron 인증 — 외부 무단 호출 차단. Production only 권장.
#   Vercel Cron 이 자동으로 Authorization: Bearer ${CRON_SECRET} 첨부.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Vercel REST API 자동화 토큰 (AI 협업 — env 추가, 재배포, 도메인 관리 자동 처리)
#   발급: https://vercel.com/account/tokens
#   사용 후 회수는 같은 페이지에서 Revoke.
#   Production 배포에는 사용 안 됨 (로컬 자동화 전용).
# ─────────────────────────────────────────────────────────────
VERCEL_TOKEN=

# ─────────────────────────────────────────────────────────────
# 공공데이터포털(data.go.kr) — 건강보험심사평가원 병원정보서비스
#   /admin/clinics '병원 정보 가져오기'(전국 피부과 의원 동기화)용 서버 전용 키.
#   1) https://www.data.go.kr → '건강보험심사평가원_병원정보서비스' 활용신청
#   2) 마이페이지 → 일반 인증키(Decoding) 값을 그대로 입력 (코드에서 encodeURIComponent 처리)
#   비어 있으면 sync API 가 운영자용 안내 메시지로 차단됨.
# ─────────────────────────────────────────────────────────────
DATA_GO_KR_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────
# Google Search Console — 관리자 대시보드 '유입 검색어' 위젯 (서버 전용, 미설정 시 설정 안내만 노출)
#   "무슨 검색어로 우리를 찾았는지"는 검색엔진 referrer 로 알 수 없어 GSC Search Analytics API 로만 조회.
#   서비스 계정(JWT 서버-서버 인증)이라 사용자 재동의 불필요.
#   1) Google Cloud Console → 서비스 계정 생성 → JSON 키 발급, 'Search Console API' 사용 설정
#   2) 서치콘솔(search.google.com/search-console) → 설정 → 사용자 및 권한 → 그 서비스 계정
#      이메일을 '전체' 또는 '제한'으로 추가 (안 하면 403)
#   3) 아래 3개 값 입력 후 재배포. GOOGLE_SC_SA_PRIVATE_KEY 는 PEM 전체(개행은 \n 리터럴로 이스케이프).
#   - GOOGLE_SC_SITE_URL: URL 접두어 속성이면 https://pibutenten.kr/ · 도메인 속성이면 sc-domain:pibutenten.kr
# ─────────────────────────────────────────────────────────────
GOOGLE_SC_SA_EMAIL=
GOOGLE_SC_SA_PRIVATE_KEY=
GOOGLE_SC_SITE_URL=
