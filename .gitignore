# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# Claude memory (Dropbox 동기화용 사본 — API key 포함이라 git push 금지)
.claude-memory/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# editor auto-save backups (e.g. file.ts.tmp.31076.1778410620914)
*.tmp.*
